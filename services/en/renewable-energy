<script>
  (function() {
    const links = document.querySelectorAll('.page-nav-link[data-target]');
    const targets = Array.from(links).map(l => document.getElementById(l.dataset.target)).filter(Boolean);
    function onScroll() {
      let current = targets[0];
      targets.forEach(t => { if (window.scrollY >= t.offsetTop - 160) current = t; });
      links.forEach(l => l.classList.toggle('active', l.dataset.target === (current && current.id)));
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>
